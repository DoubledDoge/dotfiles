root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{js,ts,jsx,tsx,json,yml,yaml,css,scss,less,sass,html,xml}]
indent_size = 2

[*.py]
max_line_length = 88

[*.cs]
indent_style = tab

[*.go]
indent_style = tab

[*.md]
trim_trailing_whitespace = false
max_line_length = 80

[*.{sh,bash,zsh}]
end_of_line = lf
indent_size = 2

[*.{ini,cfg,conf,toml}]
indent_size = 2

[*.sql]
indent_size = 2

[Makefile]
indent_style = tab
